{
  "name": "grant-management-portal",
  "version": "1.0.0",
  "description": "Secure Grant Management Portal with RBAC and OAuth 2.0",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "NODE_ENV=test dotenv -e .env.test -- jest --forceExit --detectOpenHandles --runInBand",
    "test:coverage": "NODE_ENV=test dotenv -e .env.test -- jest --coverage --forceExit --detectOpenHandles --runInBand",
    "test:watch": "NODE_ENV=test dotenv -e .env.test -- jest --watch --runInBand"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.1"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 60,
        "functions": 70,
        "lines": 70
      }
    },
    "coverageReporters": [
      "lcov",
      "text",
      "json"
    ],
    "testTimeout": 30000
  }
}
